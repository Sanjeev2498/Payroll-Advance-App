# Test Environment Variables
NODE_ENV=test
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/payroll_test?schema=public"
JWT_SECRET="test-jwt-secret-key-for-testing-purposes"
JWT_REFRESH_SECRET="test-refresh-secret-key-for-testing"
PORT=3001

# Test-specific settings
LOG_LEVEL=error
BCRYPT_ROUNDS=4

# Disable external services in test
DISABLE_EXTERNAL_APIS=true