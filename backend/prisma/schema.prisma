// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// CORE TENANT AND USER MANAGEMENT
// ============================================================================

model Company {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  slug      String   @unique @db.VarChar(50)
  settings  Json?    @db.JsonB
  branding  Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  users          User[]
  clients        Client[]
  employees      Employee[]
  payrollRuns    PayrollRun[]
  shiftTemplates ShiftTemplate[]

  @@map("companies")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  companyId    String    @map("company_id") @db.Uuid
  email        String    @unique @db.VarChar(255)
  firstName    String    @map("first_name") @db.VarChar(50)
  lastName     String    @map("last_name") @db.VarChar(50)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  role         UserRole  @default(EMPLOYEE)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  company           Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shiftNotifications ShiftNotification[]

  @@index([companyId])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  MANAGER
  SUPERVISOR
  EMPLOYEE
}

// ============================================================================
// CLIENT AND SITE MANAGEMENT
// ============================================================================

model Client {
  id                 String         @id @default(uuid()) @db.Uuid
  companyId          String         @map("company_id") @db.Uuid
  name               String         @db.VarChar(100)
  contactEmail       String         @map("contact_email") @db.VarChar(255)
  contactInfo        Json?          @map("contact_info") @db.JsonB
  contractStatus     ContractStatus @default(ACTIVE) @map("contract_status")
  contractStart      DateTime?      @map("contract_start") @db.Date
  contractEnd        DateTime?      @map("contract_end") @db.Date
  billingPreferences Json?          @map("billing_preferences") @db.JsonB
  createdAt          DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sites    Site[]
  invoices Invoice[]

  @@index([companyId])
  @@index([companyId, contractStatus])
  @@map("clients")
}

enum ContractStatus {
  ACTIVE
  PENDING
  EXPIRED
  TERMINATED
}

model Site {
  id                 String            @id @default(uuid()) @db.Uuid
  clientId           String            @map("client_id") @db.Uuid
  name               String            @db.VarChar(100)
  address            Json              @db.JsonB
  accessRequirements Json?             @map("access_requirements") @db.JsonB
  safetyProtocols    Json?             @map("safety_protocols") @db.JsonB
  operationalStatus  OperationalStatus @default(ACTIVE) @map("operational_status")
  contactInfo        Json?             @map("contact_info") @db.JsonB
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignments    Assignment[]
  shifts         Shift[]
  shiftTemplates ShiftTemplate[]

  @@index([clientId])
  @@index([operationalStatus])
  @@map("sites")
}

enum OperationalStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  SUSPENDED
}

// ============================================================================
// EMPLOYEE AND WORKFORCE MANAGEMENT
// ============================================================================

model Employee {
  id               String           @id @default(uuid()) @db.Uuid
  companyId        String           @map("company_id") @db.Uuid
  employeeNumber   String           @map("employee_number") @db.VarChar(20)
  firstName        String           @map("first_name") @db.VarChar(50)
  lastName         String           @map("last_name") @db.VarChar(50)
  email            String?          @db.VarChar(255)
  phone            String?          @db.VarChar(20)
  address          Json?            @db.JsonB
  
  // Indian Identity Documents
  aadhaarNumber    String?          @map("aadhaar_number") @db.VarChar(12)  // 12 digits with checksum
  panNumber        String?          @map("pan_number") @db.VarChar(10)      // 10 alphanumeric characters
  
  certifications   Json?            @db.JsonB
  skills           String[]         @db.VarChar(50)
  metadata         Json?            @db.JsonB
  employmentStatus EmploymentStatus @default(ACTIVE) @map("employment_status")
  hireDate         DateTime         @map("hire_date") @db.Date
  terminationDate  DateTime?        @map("termination_date") @db.Date
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignments        Assignment[]
  attendanceRecords  Attendance[]
  payrollItems       PayrollItem[]
  shiftNotifications ShiftNotification[]

  @@unique([companyId, employeeNumber])
  @@unique([aadhaarNumber]) // Aadhaar must be unique across all employees
  @@unique([panNumber])     // PAN must be unique across all employees
  @@index([companyId])
  @@index([companyId, employmentStatus])
  @@index([skills])
  @@map("employees")
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  TERMINATED
  ON_LEAVE
}

model Assignment {
  id               String           @id @default(uuid()) @db.Uuid
  employeeId       String           @map("employee_id") @db.Uuid
  siteId           String           @map("site_id") @db.Uuid
  role             String           @db.VarChar(50)
  responsibilities Json?            @db.JsonB
  hourlyRate       Decimal          @map("hourly_rate") @db.Decimal(10, 2)
  status           AssignmentStatus @default(ACTIVE)
  startDate        DateTime         @map("start_date") @db.Date
  endDate          DateTime?        @map("end_date") @db.Date
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  site     Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  shifts   Shift[]

  @@index([employeeId])
  @@index([siteId])
  @@index([status])
  @@map("assignments")
}

enum AssignmentStatus {
  ACTIVE
  INACTIVE
  COMPLETED
  CANCELLED
}

// ============================================================================
// SHIFT SCHEDULING AND ATTENDANCE
// ============================================================================

model Shift {
  id                String           @id @default(uuid()) @db.Uuid
  assignmentId      String?          @map("assignment_id") @db.Uuid
  siteId            String           @map("site_id") @db.Uuid
  templateId        String?          @map("template_id") @db.Uuid
  shiftDate         DateTime         @map("shift_date") @db.Date
  startTime         DateTime         @map("start_time") @db.Time
  endTime           DateTime         @map("end_time") @db.Time
  shiftType         ShiftType        @default(REGULAR) @map("shift_type")
  status            ShiftStatus      @default(SCHEDULED)
  priority          ShiftPriority    @default(NORMAL)
  isRecurring       Boolean          @default(false) @map("is_recurring")
  recurringPattern  Json?            @map("recurring_pattern") @db.JsonB
  coverageRequired  Int              @default(1) @map("coverage_required")
  coverageAssigned  Int              @default(0) @map("coverage_assigned")
  skillRequirements Json?            @map("skill_requirements") @db.JsonB
  shiftRequirements Json?            @map("shift_requirements") @db.JsonB
  breakSchedule     Json?            @map("break_schedule") @db.JsonB
  modificationLog   Json?            @map("modification_log") @db.JsonB
  notes             Json?            @db.JsonB
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  assignment        Assignment?      @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  site              Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  template          ShiftTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  attendanceRecords Attendance[]
  notifications     ShiftNotification[]

  @@index([assignmentId])
  @@index([siteId])
  @@index([templateId])
  @@index([shiftDate])
  @@index([status])
  @@index([isRecurring])
  @@index([priority])
  @@map("shifts")
}

enum ShiftType {
  REGULAR
  OVERTIME
  HOLIDAY
  EMERGENCY
  TRAINING
  MAINTENANCE
}

enum ShiftStatus {
  DRAFT
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  NEEDS_COVERAGE
}

enum ShiftPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum RecurrenceType {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  CUSTOM
}

enum NotificationType {
  SHIFT_ASSIGNED
  SHIFT_CHANGED
  SHIFT_CANCELLED
  COVERAGE_REQUEST
  SHIFT_REMINDER
  OVERTIME_ALERT
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  ACKNOWLEDGED
  FAILED
}

model Attendance {
  id               String           @id @default(uuid()) @db.Uuid
  employeeId       String           @map("employee_id") @db.Uuid
  shiftId          String           @map("shift_id") @db.Uuid
  clockIn          DateTime?        @map("clock_in") @db.Timestamptz
  clockOut         DateTime?        @map("clock_out") @db.Timestamptz
  locationData     Json?            @map("location_data") @db.JsonB
  status           AttendanceStatus @default(PENDING)
  verificationData Json?            @map("verification_data") @db.JsonB
  notes            String?          @db.Text
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift    Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([shiftId])
  @@index([clockIn])
  @@index([status])
  @@map("attendance")
}

enum AttendanceStatus {
  PENDING
  PRESENT
  ABSENT
  LATE
  EARLY_DEPARTURE
  OVERTIME
}

// ============================================================================
// PAYROLL AND BILLING
// ============================================================================

model PayrollRun {
  id             String        @id @default(uuid()) @db.Uuid
  companyId      String        @map("company_id") @db.Uuid
  runNumber      String        @map("run_number") @db.VarChar(50)
  payPeriodStart DateTime      @map("pay_period_start") @db.Date
  payPeriodEnd   DateTime      @map("pay_period_end") @db.Date
  status         PayrollStatus @default(DRAFT)
  totalAmount    Decimal       @default(0) @map("total_amount") @db.Decimal(12, 2)
  processedAt    DateTime?     @map("processed_at") @db.Timestamptz
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payrollItems PayrollItem[]

  @@unique([companyId, runNumber])
  @@index([companyId])
  @@index([status])
  @@map("payroll_runs")
}

enum PayrollStatus {
  DRAFT
  PROCESSING
  COMPLETED
  CANCELLED
}

model PayrollItem {
  id              String          @id @default(uuid()) @db.Uuid
  payrollRunId    String          @map("payroll_run_id") @db.Uuid
  employeeId      String          @map("employee_id") @db.Uuid
  itemType        PayrollItemType @map("item_type")
  description     String          @db.VarChar(255)
  amount          Decimal         @db.Decimal(10, 2)
  calculationData Json?           @map("calculation_data") @db.JsonB
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([payrollRunId])
  @@index([employeeId])
  @@index([itemType])
  @@map("payroll_items")
}

enum PayrollItemType {
  BASIC_PAY
  OVERTIME
  BONUS
  ALLOWANCE
  TAX_DEDUCTION
  SOCIAL_SECURITY
  HEALTH_INSURANCE
  OTHER_DEDUCTION
}

model Invoice {
  id                 String        @id @default(uuid()) @db.Uuid
  clientId           String        @map("client_id") @db.Uuid
  invoiceNumber      String        @map("invoice_number") @db.VarChar(50)
  billingPeriodStart DateTime      @map("billing_period_start") @db.Date
  billingPeriodEnd   DateTime      @map("billing_period_end") @db.Date
  subtotal           Decimal       @db.Decimal(12, 2)
  taxAmount          Decimal       @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount        Decimal       @map("total_amount") @db.Decimal(12, 2)
  status             InvoiceStatus @default(DRAFT)
  dueDate            DateTime      @map("due_date") @db.Date
  paidAt             DateTime?     @map("paid_at") @db.Timestamptz
  
  // Additional fields for Indian billing compliance
  gstDetails         Json?         @map("gst_details") @db.JsonB
  deploymentSummary  Json?         @map("deployment_summary") @db.JsonB
  additionalCharges  Json?         @map("additional_charges") @db.JsonB
  notes              String?       @db.Text
  paymentReference   String?       @map("payment_reference") @db.VarChar(255)
  
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([invoiceNumber])
  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

// ============================================================================
// SHIFT SCHEDULING SYSTEM EXTENSIONS
// ============================================================================

model ShiftTemplate {
  id                String        @id @default(uuid()) @db.Uuid
  companyId         String        @map("company_id") @db.Uuid
  name              String        @db.VarChar(100)
  description       String?       @db.Text
  siteId            String?       @map("site_id") @db.Uuid
  startTime         DateTime      @map("start_time") @db.Time
  endTime           DateTime      @map("end_time") @db.Time
  shiftType         ShiftType     @default(REGULAR) @map("shift_type")
  coverageRequired  Int           @default(1) @map("coverage_required")
  skillRequirements Json?         @map("skill_requirements") @db.JsonB
  shiftRequirements Json?         @map("shift_requirements") @db.JsonB
  breakSchedule     Json?         @map("break_schedule") @db.JsonB
  recurrencePattern Json?         @map("recurrence_pattern") @db.JsonB
  isActive          Boolean       @default(true) @map("is_active")
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site    Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)
  shifts  Shift[]

  @@index([companyId])
  @@index([siteId])
  @@index([isActive])
  @@map("shift_templates")
}

model ShiftNotification {
  id            String             @id @default(uuid()) @db.Uuid
  shiftId       String             @map("shift_id") @db.Uuid
  userId        String?            @map("user_id") @db.Uuid
  employeeId    String?            @map("employee_id") @db.Uuid
  type          NotificationType
  title         String             @db.VarChar(255)
  message       String             @db.Text
  status        NotificationStatus @default(PENDING)
  scheduledFor  DateTime?          @map("scheduled_for") @db.Timestamptz
  sentAt        DateTime?          @map("sent_at") @db.Timestamptz
  readAt        DateTime?          @map("read_at") @db.Timestamptz
  metadata      Json?              @db.JsonB
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  // Relationships
  shift    Shift     @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([shiftId])
  @@index([userId])
  @@index([employeeId])
  @@index([type])
  @@index([status])
  @@index([scheduledFor])
  @@map("shift_notifications")
}
