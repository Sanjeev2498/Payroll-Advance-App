{
  "name": "security-workforce-payroll-backend",
  "version": "1.0.0",
  "description": "Backend API for Security Workforce & Payroll Management System",
  "author": "Kiro Development Team",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset",
    "db:setup": "node scripts/setup-database.js",
    "db:test": "node scripts/test-database.js",
    "db:seed": "ts-node prisma/seed.ts",
    "rls:setup": "node scripts/setup-rls.js",
    "rls:test": "node scripts/test-rls.js",
    "rls:test-simple": "node scripts/test-rls-simple.js",
    "rls:validate": "node -e \"require('./scripts/setup-rls.js')().then(() => require('./scripts/test-rls.js')())\"",
    "test:property": "jest --testPathPattern=property-tests --verbose",
    "test:property-fast": "jest --testPathPattern=property-tests --verbose --runInBand",
    "ci:lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "ci:test": "jest --ci --coverage --watchAll=false",
    "ci:test-property": "jest --testPathPattern=property-tests --ci --watchAll=false",
    "ci:build": "npm run build",
    "ci:audit": "npm audit --audit-level moderate",
    "ci:setup": "npm run prisma:generate && npm run prisma:deploy && npm run rls:setup",
    "ci:validate": "npm run ci:lint && npm run ci:test && npm run ci:build"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.11.3",
    "prisma": "^5.22.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^3.0.13",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "fast-check": "^4.8.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "uuid": "^14.0.0"
  }
}
